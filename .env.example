# Copy this file to .env and fill in your values.
# .env is never committed to git.

# ── Scraper mode ────────────────────────────────────────────────
SCRAPER_MODE=current        # current | classic
HEADLESS=false              # false = headed (local), true = headless (Docker/server)
TEST_MODE=false             # true = writes to test-data/ instead of output/

# ── DigitalOcean PostgreSQL ─────────────────────────────────────
DB_HOST=partpilot-main-db-do-user-35023198-0.h.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=defaultdb
DB_USER=doadmin
DB_PASSWORD=your_password_here
DB_SSLMODE=require

# ── Optional: rotating proxy ────────────────────────────────────
# PROXY_URL=http://user:pass@proxy-host:port
